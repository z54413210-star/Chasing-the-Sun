  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 829b12bc487898c44ba9bed64d1ca9b3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  kind: 2
  nextSceneName: 
  loadSceneWhenFinished: 0
  onBeforeLoadScene:
    m_PersistentCalls:
      m_Calls: []
  darkIntroSegments:
  - Hello! I know it's your first time to come here, a totally different and magical
    world.
  - Don't be afraid. I will accompany you
  introMessage: "Hey\u2026\nYou made it this far.\nDo you remember now?\nThe light
    you were chasing.\nCome with me.\nLet\u2019s watch it rise\u2014together."
  photoSprite: {fileID: 21300000, guid: 2c2bd39331c06ad43b9bfc97bfae0596, type: 3}
  transitionParagraphs:
  - The night came to an end
  - Light touched the horizon\nI stopped running.
  - She was there\nAs if she had always been.
  - No words\nNone were needed.
  - "I reached out\\nNot to chase\u2014 \\nbut to hold on."
  - She was never lost\nOnly waiting\nBeside me
  - So we sat together\nWatching the sun rise
  - No more running\nNo more hiding\nJust forward.
  - "Together\u2014 \\ninto the light. "
  endPhotoSprite: {fileID: 21300000, guid: 03d54aa7868b84e44b6450bccf38fdeb, type: 3}
  chapterTitleText: 
  chapterTitleFontSize: 0
  endCreditsSegments:
  - Thanks for your playing.
  - For walking this path\nstep by step\nthrough the dark and the quiet.
  - This journey may end here\nbut yours does not.
  - There will be days of doubt\nDays of silence\nDays when the light feels far away.
  - "When that happens\\nremember what you found here\u2014"
  - The courage to look back\nThe strength to keep going\nAnd the part of you that
    never truly left.
  - Take it with you\nAnd when the world feels heavy again\nlift your eyes.
  - The sunrise is always there\nwaiting for you.
  darkenDuration: 1.2
  brightenDuration: 1.35
  darkSegmentFadeIn: 0.55
  darkSegmentPause: 0.35
  darkIntroFadeOutDuration: 0.75
  introFadeInDuration: 0.9
